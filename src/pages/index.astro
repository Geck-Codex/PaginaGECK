---
import Layout from '@/layouts/MainLayout.astro';
import VideoBackground from '@/components/VideoBackground.jsx';
import Header from '@/components/hero/Header.jsx';
import ProjectCarousel from '@/components/hero/ProjectCarousel.jsx';
import SpecialtiesShowcase from '@/components/hero/SpecialtiesShowcase.jsx';
import Carrusel from '@/components/hero/Carrusel.jsx';
import StatsSection from '@/components/hero/StatsSection.jsx';
---

<Layout
  title="Geck Codex | Desarrollo Web, Apps Móviles e IA en México"
  description="Agencia de desarrollo tecnológico en Parral, Chihuahua. Creamos sitios web, apps móviles, soluciones de IA y e-commerce para empresas en México y Estados Unidos."
  canonical="https://geckcodex.com/"
>
  <VideoBackground client:load>
    <Header client:load />
  </VideoBackground>

  <ProjectCarousel client:load />
  <SpecialtiesShowcase client:load />
  <Carrusel client:load />
  <StatsSection client:load />
</Layout>
